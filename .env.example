# ── Devin v3 API ──────────────────────────────────────────────
DEVIN_API_KEY=              # starts with cog_
DEVIN_ORG_ID=               # starts with org-
DEVIN_API_BASE=https://api.devin.ai

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=               # PAT with repo scope
GITHUB_REPO=ShaunakPandya/superset
GITHUB_WEBHOOK_SECRET=      # any random string, used for HMAC verification

# ── Orchestrator behavior ─────────────────────────────────────
TRIGGER_LABEL=devin-remediate
MAX_CONCURRENT_SESSIONS=3
POLL_INTERVAL_SECONDS=45
DB_PATH=/data/orchestrator.db
